{
	"name": "ditis",
	"version": "0.1.0",
	"scripts": {
		"dev": "bun run dev.ts",
		"build": "NODE_ENV=production bunx @tailwindcss/cli -i styles/app.css -o public/app.css --minify && NODE_ENV=production bun run build.ts",
		"start": "bun run src/index.ts",
		"lint": "bunx --bun @biomejs/biome check --write",
		"tsc": "bunx tsc --noEmit",
		"test": "bun run test",
		"db:browse": "bunx drizzle-kit studio --port 3000 --verbose"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"@deck.gl/mapbox": "^9.2.11",
		"@hono/standard-validator": "^0.2.2",
		"@standard-community/standard-json": "^0.3.5",
		"@standard-community/standard-openapi": "^0.2.9",
		"deck.gl": "^9.2.11",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.8",
		"hono-openapi": "^1.3.0",
		"htmx.org": "^2.0.8",
		"maplibre-gl": "^5.20.1",
		"openapi-types": "^12.1.3",
		"pdf-parse": "^2.4.5",
		"tesseract.js": "^7.0.0",
		"zod": "^4.3.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/cli": "^4.2.1",
		"@types/bun": "latest",
		"drizzle-kit": "^0.31.9",
		"tailwindcss": "^4.2.1"
	}
}
